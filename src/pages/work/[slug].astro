---
export const prerender = true;
import BaseLayout from "../../layouts/BaseLayout.astro";
import CTAStrip from "../../components/CTAStrip.astro";
import Testimonial from "../../components/Testimonial.astro";
import { work } from "../../data/work";

export function getStaticPaths() {
  return work.map((c) => ({ params: { slug: c.slug }, props: { study: c } }));
}

const { study } = Astro.props;

const idx = work.findIndex((w) => w.slug === study.slug);
const next = work[(idx + 1) % work.length];
---

<BaseLayout
  title={`${study.client} — ${study.title}`}
  description={study.summary}
>
  <article>
    <header class="border-b border-[color:var(--color-line)] pt-16 pb-16 md:pt-24 md:pb-24">
      <div class="container-wide">
        <a href="/work" class="link-underline font-mono text-xs uppercase tracking-[0.18em]">← All work</a>

        <p class="eyebrow mt-10">{study.hero.eyebrow}</p>
        <h1 class="mt-6 max-w-5xl font-display text-5xl font-semibold leading-[0.95] tracking-[-0.03em] md:text-[5.5rem]">
          {study.title}
        </h1>
        <p class="mt-8 max-w-3xl text-lg text-[color:var(--color-bone-dim)] md:text-xl">{study.hero.statement}</p>

        <dl class="mt-14 grid grid-cols-2 gap-px overflow-hidden rounded-3xl border border-[color:var(--color-line)] bg-[color:var(--color-line)] md:grid-cols-4">
          <div class="bg-[color:var(--color-ink-2)] p-6">
            <dt class="font-mono text-[10px] uppercase tracking-[0.18em] text-[color:var(--color-mute)]">Client</dt>
            <dd class="mt-3 font-display text-xl tracking-tight">{study.client}</dd>
          </div>
          <div class="bg-[color:var(--color-ink-2)] p-6">
            <dt class="font-mono text-[10px] uppercase tracking-[0.18em] text-[color:var(--color-mute)]">Industry</dt>
            <dd class="mt-3 font-display text-xl tracking-tight">{study.industry}</dd>
          </div>
          <div class="bg-[color:var(--color-ink-2)] p-6">
            <dt class="font-mono text-[10px] uppercase tracking-[0.18em] text-[color:var(--color-mute)]">Region</dt>
            <dd class="mt-3 font-display text-xl tracking-tight">{study.region}</dd>
          </div>
          <div class="bg-[color:var(--color-ink-2)] p-6">
            <dt class="font-mono text-[10px] uppercase tracking-[0.18em] text-[color:var(--color-mute)]">Engagement</dt>
            <dd class="mt-3 font-display text-xl tracking-tight">{study.year}</dd>
          </div>
        </dl>
      </div>
    </header>

    <section class="py-24 md:py-32">
      <div class="container-wide">
        <p class="eyebrow">Results</p>
        <h2 class="mt-6 font-display text-5xl font-medium leading-[0.95] tracking-tight md:text-7xl">The numbers.</h2>

        <dl class="mt-12 grid grid-cols-2 gap-6 md:grid-cols-4">
          {study.results.map((r) => (
            <div class="rounded-3xl border border-[color:var(--color-line)] bg-[color:var(--color-ink-2)] p-8">
              <dt class="font-mono text-[11px] uppercase tracking-[0.18em] text-[color:var(--color-bone-dim)]">{r.label}</dt>
              <dd class="mt-6 font-display text-5xl font-semibold tracking-tight text-[color:var(--color-accent)]">{r.value}</dd>
            </div>
          ))}
        </dl>
      </div>
    </section>

    <section class="border-t border-[color:var(--color-line)] py-24 md:py-32">
      <div class="container-wide grid gap-16 md:grid-cols-[1fr_1.6fr]">
        <div>
          <p class="eyebrow">The brief</p>
          <h2 class="mt-6 font-display text-4xl font-medium leading-tight tracking-tight md:text-5xl">{study.summary}</h2>
        </div>
        <div>
          <p class="eyebrow">Scope</p>
          <ul class="mt-6 divide-y divide-[color:var(--color-line)] border-y border-[color:var(--color-line)]">
            {study.scope.map((s, i) => (
              <li class="flex items-start gap-6 py-4">
                <span class="font-mono text-xs text-[color:var(--color-mute)]">{String(i + 1).padStart(2, "0")}</span>
                <p class="text-[color:var(--color-bone)]">{s}</p>
              </li>
            ))}
          </ul>
          <ul class="mt-8 flex flex-wrap gap-2">
            {study.services.map((s) => (
              <li class="rounded-full border border-[color:var(--color-line)] px-3 py-1 text-xs text-[color:var(--color-bone-dim)]">{s}</li>
            ))}
          </ul>
        </div>
      </div>
    </section>

    <section class="border-t border-[color:var(--color-line)] py-24 md:py-32">
      <div class="container-wide">
        <p class="eyebrow">Approach</p>
        <h2 class="mt-6 font-display text-5xl font-medium leading-[0.95] tracking-tight md:text-7xl">How we ran the program.</h2>

        <div class="mt-16 grid gap-px overflow-hidden rounded-3xl border border-[color:var(--color-line)] bg-[color:var(--color-line)] md:grid-cols-3">
          {study.approach.map((a, i) => (
            <article class="flex flex-col gap-4 bg-[color:var(--color-ink-2)] p-8">
              <span class="font-mono text-xs text-[color:var(--color-accent)]">{String(i + 1).padStart(2, "0")}</span>
              <h3 class="font-display text-2xl tracking-tight md:text-3xl">{a.heading}</h3>
              <p class="text-sm text-[color:var(--color-bone-dim)]">{a.body}</p>
            </article>
          ))}
        </div>
      </div>
    </section>

    {study.quote && (
      <Testimonial body={study.quote.body} name={study.quote.name} role={study.quote.role} />
    )}

    <section class="border-t border-[color:var(--color-line)] py-20 md:py-28">
      <div class="container-wide flex flex-col justify-between gap-8 md:flex-row md:items-end">
        <div>
          <p class="eyebrow">Next case study</p>
          <a href={`/work/${next.slug}`} class="mt-6 block font-display text-4xl font-medium tracking-tight hover:text-[color:var(--color-accent)] md:text-6xl">
            {next.client} →
          </a>
        </div>
        <a href="/work" class="btn-ghost">All work</a>
      </div>
    </section>
  </article>

  <CTAStrip
    eyebrow="Similar problem?"
    heading="Tell us the number you need to move."
  />
</BaseLayout>
