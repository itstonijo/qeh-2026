---
import { services } from "../data/services";
import { url } from "../lib/url";
---

<section id="services" class="border-t border-[color:var(--color-line)] py-24 md:py-32">
  <div class="container-wide">
    <div class="grid gap-10 md:grid-cols-[1fr_1.4fr] md:items-end">
      <div>
        <p class="eyebrow">What we do</p>
        <h2 class="mt-6 font-display text-5xl font-medium leading-[0.95] tracking-tight md:text-7xl">
          One team. One funnel. <span class="text-[color:var(--color-mute)]">One P&amp;L.</span>
        </h2>
      </div>
      <p class="text-lg text-[color:var(--color-bone-dim)]">
        Search, paid, content, CRM and build sit in one room — so the program compounds instead of fighting itself across five agency invoices.
      </p>
    </div>

    <ul class="mt-16 divide-y divide-[color:var(--color-line)] border-y border-[color:var(--color-line)]">
      {services.map((s) => (
        <li class="group">
          <a href={url(s.href)} class="flex flex-col gap-4 py-8 md:flex-row md:items-start md:gap-10">
            <div class="flex w-full items-center justify-between md:w-44">
              <span class="font-mono text-xs text-[color:var(--color-mute)]">{s.number} —</span>
              <span class="md:hidden text-[color:var(--color-accent)]">→</span>
            </div>
            <div class="flex-1">
              <h3 class="font-display text-3xl font-medium tracking-tight transition-colors group-hover:text-[color:var(--color-accent)] md:text-5xl">
                {s.title}
              </h3>
              <p class="mt-3 max-w-2xl text-[color:var(--color-bone-dim)]">{s.short}</p>
              <ul class="mt-5 flex flex-wrap gap-2">
                {s.capabilities.slice(0, 4).map((c) => (
                  <li class="rounded-full border border-[color:var(--color-line)] px-3 py-1 text-xs text-[color:var(--color-bone-dim)]">{c}</li>
                ))}
              </ul>
            </div>
            <div class="hidden self-center text-[color:var(--color-mute)] transition-colors group-hover:text-[color:var(--color-accent)] md:block">
              <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
            </div>
          </a>
        </li>
      ))}
    </ul>
  </div>
</section>
