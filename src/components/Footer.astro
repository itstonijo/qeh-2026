---
import { site, servicesNav, nav } from "../data/site";
import { url } from "../lib/url";
const year = new Date().getFullYear();
---

<footer class="relative mt-32 border-t border-[color:var(--color-line)] bg-[color:var(--color-ink-2)]">
  <div class="container-wide py-20 md:py-28">
    <div class="grid gap-16 lg:grid-cols-[1.4fr_1fr_1fr_1fr]">
      <div>
        <p class="eyebrow">Let's build</p>
        <h2 class="mt-4 font-display text-4xl font-medium leading-[0.95] tracking-tight md:text-6xl">
          Got a number you need to move?
          <span class="text-[color:var(--color-mute)]">We probably have a plan for it.</span>
        </h2>
        <div class="mt-8 flex flex-wrap items-center gap-3">
          <a href={url("/contact")} class="btn-primary">
            Start a project
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
          </a>
          <a href={`mailto:${site.email}`} class="btn-ghost">{site.email}</a>
        </div>
      </div>

      <div>
        <p class="eyebrow">Services</p>
        <ul class="mt-5 space-y-3">
          {servicesNav.map((item) => (
            <li><a href={url(item.href)} class="text-[color:var(--color-bone)] hover:text-[color:var(--color-accent)]">{item.label}</a></li>
          ))}
        </ul>
      </div>

      <div>
        <p class="eyebrow">Studio</p>
        <ul class="mt-5 space-y-3">
          {nav.map((item) => (
            <li><a href={url(item.href)} class="text-[color:var(--color-bone)] hover:text-[color:var(--color-accent)]">{item.label}</a></li>
          ))}
        </ul>
      </div>

      <div>
        <p class="eyebrow">Where we are</p>
        <address class="mt-5 not-italic text-[color:var(--color-bone-dim)]">
          {site.address.line1}<br />
          {site.address.line2}<br />
          {site.address.country}
        </address>
        <ul class="mt-5 space-y-2">
          {site.socials.map((s) => (
            <li><a href={s.href} class="text-[color:var(--color-bone)] hover:text-[color:var(--color-accent)]">{s.label} →</a></li>
          ))}
        </ul>
      </div>
    </div>

    <div class="hairline mt-20"></div>

    <div class="mt-8 flex flex-col items-start justify-between gap-4 text-xs text-[color:var(--color-mute)] md:flex-row md:items-center">
      <p>© {year} {site.name} A performance-led digital agency. Sydney, Australia.</p>
      <p class="font-mono uppercase tracking-[0.18em]">SEO · AEO · Paid · Content · CRM · Build</p>
    </div>
  </div>

  <div aria-hidden="true" class="pointer-events-none select-none overflow-hidden">
    <p class="-mb-8 whitespace-nowrap text-center font-display text-[22vw] font-semibold leading-none tracking-tighter text-[color:var(--color-ink-3)]">
      Covert.
    </p>
  </div>
</footer>
