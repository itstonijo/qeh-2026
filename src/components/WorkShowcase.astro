---
import { work } from "../data/work";

interface Props {
  limit?: number;
  heading?: string;
  eyebrow?: string;
  showCTA?: boolean;
}

const { limit, heading = "Selected work.", eyebrow = "Case studies", showCTA = true } = Astro.props;
const items = limit ? work.slice(0, limit) : work;
---

<section class="border-t border-[color:var(--color-line)] py-24 md:py-32">
  <div class="container-wide">
    <div class="flex flex-wrap items-end justify-between gap-6">
      <div>
        <p class="eyebrow">{eyebrow}</p>
        <h2 class="mt-6 font-display text-5xl font-medium leading-[0.95] tracking-tight md:text-7xl">{heading}</h2>
      </div>
      {showCTA && (
        <a href="/work" class="btn-ghost">
          All work
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
        </a>
      )}
    </div>

    <div class="mt-16 grid grid-cols-1 gap-6 md:grid-cols-6">
      {items.map((c, i) => {
        const span =
          c.size === "lg"
            ? "md:col-span-6"
            : c.size === "md"
            ? "md:col-span-3"
            : "md:col-span-2";
        return (
          <a
            href={`/work/${c.slug}`}
            class:list={[
              "group relative isolate flex min-h-[340px] flex-col justify-between overflow-hidden rounded-3xl border border-[color:var(--color-line)] bg-[color:var(--color-ink-2)] p-7 transition-colors hover:border-[color:var(--color-bone-dim)] md:min-h-[420px]",
              span,
            ]}
          >
            <div aria-hidden="true" class={`pointer-events-none absolute inset-0 -z-10 bg-gradient-to-br ${c.accent}`}></div>
            <div aria-hidden="true" class="pointer-events-none absolute -bottom-24 -right-16 -z-10 h-72 w-72 rounded-full bg-[color:var(--color-accent)]/0 blur-3xl transition-all duration-500 group-hover:bg-[color:var(--color-accent)]/20"></div>

            <div class="flex items-center justify-between font-mono text-[11px] uppercase tracking-[0.18em] text-[color:var(--color-bone-dim)]">
              <span>{c.industry}</span>
              <span>{c.region}</span>
            </div>

            <div>
              <p class="font-mono text-xs text-[color:var(--color-mute)]">{c.client}</p>
              <h3 class:list={[
                "mt-3 font-display font-medium leading-[1.02] tracking-tight text-[color:var(--color-bone)]",
                c.size === "lg" ? "text-4xl md:text-6xl" : c.size === "md" ? "text-3xl md:text-4xl" : "text-2xl md:text-3xl",
              ]}>
                {c.title}
              </h3>

              <div class="mt-6 flex flex-wrap items-center gap-x-6 gap-y-2 text-sm text-[color:var(--color-bone-dim)]">
                {c.results.slice(0, c.size === "lg" ? 3 : 2).map((r) => (
                  <div class="flex items-baseline gap-2">
                    <span class="font-display text-xl text-[color:var(--color-bone)]">{r.value}</span>
                    <span class="text-[color:var(--color-mute)]">{r.label}</span>
                  </div>
                ))}
              </div>

              <p class="mt-6 inline-flex items-center gap-2 text-sm text-[color:var(--color-bone)] transition-colors group-hover:text-[color:var(--color-accent)]">
                Read case study
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
              </p>
            </div>
          </a>
        );
      })}
    </div>
  </div>
</section>
