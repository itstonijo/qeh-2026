# Public site URL — used for canonical, sitemap and OG
SITE_URL=https://covert.example.com

# Server bind (defaults: 127.0.0.1:4321)
HOST=0.0.0.0
PORT=4321

# Where briefs and subscribers are appended as JSON lines
DATA_DIR=./.data

# Optional: forward every brief/subscriber to a Slack/Discord/Resend webhook
# CONTACT_WEBHOOK_URL=https://hooks.slack.com/services/...

# Optional: admin endpoint token. Set this to enable GET /api/admin/submissions?token=...
# ADMIN_TOKEN=change-me
