# Public site URL — used for canonical, sitemap and OG
SITE_URL=https://covert.example.com

# Server bind (defaults: 127.0.0.1:4321)
HOST=0.0.0.0
PORT=4321

# Where briefs and subscribers are appended as JSON lines
DATA_DIR=./.data

# Optional: forward every brief/subscriber to a Slack/Discord/Resend webhook
# CONTACT_WEBHOOK_URL=https://hooks.slack.com/services/...

# Optional: admin endpoint token. Set this to enable GET /api/admin/submissions?token=...
# ADMIN_TOKEN=change-me

# Static-build overrides (used by `npm run build:static`)
# Set these to a Formspree/Resend/etc endpoint URL to keep the forms working
# on hosts that can't run server code (e.g. GitHub Pages).
# PUBLIC_FORM_ENDPOINT=https://formspree.io/f/abcd1234
# PUBLIC_NEWSLETTER_ENDPOINT=https://formspree.io/f/wxyz9876

# Base path for the deployment. For a GitHub Pages project page this is
# "/<repo>". For a custom domain or user-page repo, leave empty.
# BASE_PATH=/qeh-2026
